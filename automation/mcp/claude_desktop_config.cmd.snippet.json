{
  "mcpServers": {
    "sotn-cmd": {
      "command": "wsl.exe",
      "args": [
        "-d",
        "Ubuntu-24.04",
        "-e",
        "bash",
        "-lc",
        "cd /mnt/c/Users/YOUR_USER/path/to/SOTN-Decomp/automation/mcp && SOTN_REPO=/mnt/c/Users/YOUR_USER/path/to/SOTN-Decomp SOTN_PYTHON=/mnt/c/Users/YOUR_USER/path/to/SOTN-Decomp/.venv/bin/python ./.venv/bin/python sotn_cmd_mcp.py"
      ],
      "env": {
        "SOTN_CMD_DRYRUN": "1",
        "SOTN_CMD_MAXOUT": "20000"
      }
    }
  }
}
